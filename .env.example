SECRET_KEY=your-secret-key-here
DATABASE_URL=postgresql://user:password@localhost:5432/viera
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# AmoCRM
AMOCRM_DOMAIN=yourdomain.amocrm.ru
AMOCRM_ACCESS_TOKEN=your_access_token
AMOCRM_PIPELINE_ID=9461998
AMOCRM_STAGE_DRIP_ID=86780230
AMOCRM_STAGE_HUMAN_ID=86780234
# Этапы из которых разрешён переход в Дожим бот (Неразобранное + Новая заявка)
AMOCRM_ALLOWED_STAGE_IDS=75708506,75734750

# WazzUp24
WAZZUP_TOKEN=your_wazzup_api_token
# UUID каналов через запятую (WhatsApp, Instagram и т.д.)
WAZZUP_CHANNEL_IDS=uuid-канала-1,uuid-канала-2

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# DRY_RUN=True — WazzUp messages are only logged, not actually sent (AmoCRM stays in prod)
DRY_RUN=True
