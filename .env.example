# Django
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=yourdomain.up.railway.app,localhost

# База данных (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/viera

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# AmoCRM
AMOCRM_DOMAIN=yourdomain.amocrm.ru
AMOCRM_ACCESS_TOKEN=your_amocrm_access_token
AMOCRM_PIPELINE_ID=9461998
AMOCRM_STAGE_DRIP_ID=86780230
AMOCRM_STAGE_HUMAN_ID=86780234
# Этапы, из которых бот переводит лид в Дожим бот (Неразобранное + Новая заявка)
AMOCRM_ALLOWED_STAGE_IDS=75708506,75734750

# WazzUp24
WAZZUP_TOKEN=your_wazzup_api_token
# UUID каналов через запятую (WhatsApp, Instagram и т.д.)
WAZZUP_CHANNEL_IDS=uuid-канала-1,uuid-канала-2

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Режим тестирования: True — сообщения только логируются, клиентам не отправляются
# AmoCRM при этом работает в боевом режиме
DRY_RUN=True

# Django Admin — суперпользователь создаётся автоматически при первом запуске
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-strong-password
ADMIN_EMAIL=admin@yourdomain.com
